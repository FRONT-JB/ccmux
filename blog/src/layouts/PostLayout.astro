---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}

const { post, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmt(date: Date): string {
  return new Intl.DateTimeFormat('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

function slugUrl(entry: CollectionEntry<'posts'>): string {
  return `${base}/${entry.id.replace(/\.mdx?$/, '')}/`;
}
---

<BaseLayout title={`${title} — ccmux blog`} description={description}>
  <article class="prose">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {
          updatedDate && (
            <span>수정 {fmt(updatedDate)}</span>
          )
        }
        {
          tags.length > 0 && (
            <span class="tags">
              {tags.map((t) => <span class="tag">{t}</span>)}
            </span>
          )
        }
      </div>
      <h1>{title}</h1>
      {description && <p class="post-description">{description}</p>}
    </header>

    <slot />

    <nav class="post-nav" aria-label="Post navigation">
      {
        prev ? (
          <a href={slugUrl(prev)}>
            <span class="nav-label">← 이전 글</span>
            {prev.data.title}
          </a>
        ) : (
          <span class="nav-empty" aria-hidden="true" />
        )
      }
      {
        next ? (
          <a href={slugUrl(next)} style="text-align: right;">
            <span class="nav-label">다음 글 →</span>
            {next.data.title}
          </a>
        ) : (
          <span class="nav-empty" aria-hidden="true" />
        )
      }
    </nav>
  </article>
</BaseLayout>
